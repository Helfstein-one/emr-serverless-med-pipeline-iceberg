# ============================================================
# EMR Serverless Med Pipeline — Variáveis de Ambiente
# Para trocar de MinIO local → AWS S3 real, altere apenas
# as variáveis abaixo.
# ============================================================

# ---- Storage (MinIO / S3) ----
S3_ENDPOINT=http://minio:9000
S3_ENDPOINT_EXTERNAL=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1

# ---- Buckets ----
BRONZE_BUCKET=bronze
SILVER_BUCKET=silver
GOLD_BUCKET=gold
WAREHOUSE_BUCKET=warehouse

# ---- Nessie Catalog ----
NESSIE_URI=http://nessie:19120/api/v1
NESSIE_URI_EXTERNAL=http://localhost:19120/api/v1
NESSIE_REF=main

# ---- Spark ----
SPARK_THRIFT_HOST=spark
SPARK_THRIFT_PORT=10000
SPARK_MASTER=local[*]

# ---- Airflow ----
AIRFLOW__CORE__EXECUTOR=SequentialExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__DAGS_FOLDER=/opt/airflow/dags
AIRFLOW__WEBSERVER__SECRET_KEY=supersecretkey123
AIRFLOW_HOME=/opt/airflow
_AIRFLOW_DB_MIGRATE=true
_AIRFLOW_WWW_USER_CREATE=true
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin
